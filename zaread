#!/bin/sh
## zaread - a simple script created by paoloap.

VERSION="1.4.2"

# Exit codes:
#   1 - usage error, missing file, or missing dependency
#   2 - unsupported file format
#   3 - conversion failed

# zaread cache path
ZA_CACHE_DIR="${XDG_CACHE_HOME:-"$HOME"/.cache}/zaread"
# zaread config path
ZA_CONFIG="${XDG_CONFIG_HOME:-"$HOME"/.config}/zaread/zareadrc"

# Default reader
READER="zathura"
READER_ARG=""

# Default converters
MOBI_CMD="ebook-convert"
OFFICE_CMD="soffice"
MD_CMD="md2pdf"
TYPST_CMD="typst"
TYPST_ARG="compile"
MD_ARG=""
MOBI_ARG=""
OFFICE_ARG=""

# Verbose output (override with -v flag or set in config)
VERBOSE=0

log() {
	if [ "$VERBOSE" -eq 1 ]; then
		echo "$@"
	fi
}

err() {
	echo "zaread: $*" >&2
}

usage() {
	echo "Usage: zaread [-v] [-f] [-c] [-V] [-h] <file>"
}

# Run a converter that writes to a .part temp file, handle errors, rename on success.
# Usage: run_convert <display_name> <cmd> [args...]
run_convert() {
	_name="$1"; shift
	if ! "$@"; then
		rm -f "$ZA_CACHE_DIR/$pdffile.part"
		err "conversion failed: $_name $file"
		exit 3
	fi
	mv "$ZA_CACHE_DIR/$pdffile.part" "$ZA_CACHE_DIR/$pdffile"
}

# Override any of the above via config file
# shellcheck disable=SC1090
[ -f "$ZA_CONFIG" ] && . "$ZA_CONFIG"

FORCE=0

while getopts ":vhcfV" opt; do
	case "$opt" in
	v) VERBOSE=1 ;;
	f) FORCE=1 ;;
	c)
		if [ -d "$ZA_CACHE_DIR" ]; then
			rm -rf "${ZA_CACHE_DIR:?}"/*
			echo "Cache cleared: $ZA_CACHE_DIR"
		else
			echo "No cache directory found."
		fi
		exit 0
		;;
	V)
		echo "zaread $VERSION"
		exit 0
		;;
	h) usage; exit 0 ;;
	*) err "unknown option: -$OPTARG"; usage >&2; exit 1 ;;
	esac
done
shift $((OPTIND - 1))

if [ "$#" -eq 0 ]; then
	err "no file specified"
	usage >&2
	exit 1
fi

if [ "$#" -ne 1 ]; then
	err "expected one file, got $#"
	exit 1
fi

path="$1"

if [ ! -f "$path" ]; then
	err "file not found: $path"
	exit 1
fi

if ! command -v "$READER" >/dev/null; then
	err "$READER is not in PATH"
	exit 1
fi

if ! command -v file >/dev/null; then
	err "file is not in PATH (needed for MIME detection)"
	exit 1
fi

# Create cache dir if needed (deferred so -V/-h/-c don't create it as a side effect)
[ -d "$ZA_CACHE_DIR" ] || mkdir -p "$ZA_CACHE_DIR" || { err "cannot create cache directory: $ZA_CACHE_DIR"; exit 1; }

log "Reader: $READER"

## Resolve file path

file="$(basename "$path")"
log "File: $file"

directory="$(cd "$(dirname "$path")" && pwd)" || { err "cannot resolve path: $path"; exit 1; }
log "Directory: $directory"

# Detect MIME type
file_mt="$(file --mime-type "$directory/$file")"
file_mt="${file_mt#*: }"
log "MIME type: $file_mt"

# Cache key: CRC_BYTECOUNT_filename.pdf
_ckout="$(cksum "$directory/$file")"
_crc="${_ckout%% *}"; _rest="${_ckout#* }"
_bytes="${_rest%% *}"
pdffile="${_crc}_${_bytes}_${file}.pdf"
log "Cache file: $pdffile"

file_converter=""

# Check for cached conversion first (skip with -f)
if [ "$FORCE" -eq 0 ] && [ -f "$ZA_CACHE_DIR/$pdffile" ]; then
	file_converter="none_converted"
else
	if [ "$FORCE" -eq 1 ] && [ -f "$ZA_CACHE_DIR/$pdffile" ]; then
		log "Force re-conversion (ignoring cache)"
	fi
	case "$file_mt" in
	"application/pdf" | "image/vnd.djvu" | "application/epub+zip")
		file_converter="none_original"
		;;
	"application/vnd.openxmlformats-officedocument.wordprocessingml.document" | \
		"application/vnd.openxmlformats-officedocument.spreadsheetml.sheet" | \
		"application/vnd.openxmlformats-officedocument.presentationml.presentation" | \
		"application/msword" | \
		"application/vnd.ms-excel" | \
		"application/vnd.ms-powerpoint" | \
		"application/vnd.oasis.opendocument.text" | \
		"application/vnd.oasis.opendocument.spreadsheet" | \
		"application/vnd.oasis.opendocument.presentation" | \
		"text/rtf" | \
		"text/csv")
		file_converter="$OFFICE_CMD"
		;;
	"application/x-mobipocket-ebook")
		file_converter="$MOBI_CMD"
		;;
	"application/octet-stream")
		case "$file" in
		*.mobi)
			file_converter="$MOBI_CMD"
			;;
		esac
		;;
	# file(1) reports macro-enabled Office formats as application/zip
	"application/zip")
		case "$file" in
		*.xlsm | *.xlsb | *.docm | *.pptm | *.ppsx | *.dotx)
			file_converter="$OFFICE_CMD"
			;;
		esac
		;;
	# file(1) sometimes reports markdown/typst as C, ObjC, Python, or text/markdown
	"text/plain" | \
		"text/x-c" | \
		"text/x-objective-c" | \
		"text/x-script.python" | \
		"text/markdown")
		case "$file" in
		*.md)
			file_converter="$MD_CMD"
			;;
		*.typ)
			file_converter="$TYPST_CMD"
			;;
		esac
		;;
	esac
fi

case "$file_converter" in
"")
	err "unsupported format: $file_mt"
	exit 2
	;;
"none_original")
	log "Opening directly"
	# shellcheck disable=SC2086
	"$READER" $READER_ARG "$directory/$file"
	;;
"none_converted")
	log "Opening from cache"
	# shellcheck disable=SC2086
	"$READER" $READER_ARG "$ZA_CACHE_DIR/$pdffile"
	;;
*)
	if ! command -v "$file_converter" >/dev/null; then
		err "$file_converter is not in PATH (needed to convert $file)"
		exit 1
	fi
	log "Converting $file with $file_converter"
	# _ARG vars intentionally unquoted to allow multi-argument values
	case "$file_converter" in
	"$OFFICE_CMD")
		case "$file" in
		.*.*)
			tmpfile="${file%.*}.pdf"
			;;
		.*)
			tmpfile="$file.pdf"
			;;
		*)
			tmpfile="${file%.*}.pdf"
			;;
		esac
		# shellcheck disable=SC2086
		if ! "$OFFICE_CMD" $OFFICE_ARG \
			"-env:UserInstallation=file:///tmp/zaread-soffice-$$" \
			--convert-to pdf "$directory/$file" --outdir "$ZA_CACHE_DIR"; then
			rm -f "$ZA_CACHE_DIR/$tmpfile"
			rm -rf "/tmp/zaread-soffice-$$"
			err "conversion failed: $OFFICE_CMD $file"
			exit 3
		fi
		rm -rf "/tmp/zaread-soffice-$$"
		mv "$ZA_CACHE_DIR/$tmpfile" "$ZA_CACHE_DIR/$pdffile"
		;;
	"$MOBI_CMD")
		# shellcheck disable=SC2086
		run_convert "$MOBI_CMD" "$MOBI_CMD" $MOBI_ARG "$directory/$file" "$ZA_CACHE_DIR/$pdffile.part"
		;;
	"$MD_CMD")
		# shellcheck disable=SC2086
		run_convert "$MD_CMD" "$MD_CMD" $MD_ARG "$directory/$file" -o "$ZA_CACHE_DIR/$pdffile.part"
		;;
	"$TYPST_CMD")
		# shellcheck disable=SC2086
		run_convert "$TYPST_CMD" "$TYPST_CMD" $TYPST_ARG "$directory/$file" "$ZA_CACHE_DIR/$pdffile.part"
		;;
	esac
	log "Opening converted file"
	# shellcheck disable=SC2086
	"$READER" $READER_ARG "$ZA_CACHE_DIR/$pdffile"
	;;
esac
